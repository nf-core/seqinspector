/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {
    withName: BWAMEM2_INDEX {
        publishDir = [
            path: { "${params.outdir}/bwamem2_index" },
            mode: params.publish_dir_mode
        ]
    }

    withName: BWAMEM2_MEM {
        publishDir = [
            path: { "${params.outdir}/bwamem2_mem" },
            mode: params.publish_dir_mode
        ]
    }

    withName: CHECKQC {
        tag = { "${run_dir.simpleName}" }
    }

    withName: FASTQC {
        ext.args = '--quiet'
    }

    withName: FQ_LINT {
        errorStrategy = {
            task.exitStatus in ((130..145) + 104) ? 'retry'  :
            params.continue_with_lint_fail        ? 'ignore' :
            'finish'
        }
        ext.args      = { params.fq_lint_args }
        publishDir = [
            path: { "${params.outdir}/fq" },
            mode: params.publish_dir_mode
        ]
    }

    withName: KRAKEN2_KRAKEN2 {
        publishDir = [
            path: { "${params.outdir}/kraken2" },
            mode: params.publish_dir_mode
        ]
    }

    withName: KRONA_KTIMPORTTAXONOMY {
        publishDir = [
            path: { "${params.outdir}/kraken2/krona" },
            mode: params.publish_dir_mode
        ]
    }

    withName: KRONA_KTUPDATETAXONOMY {
        publishDir = [
            enabled: false
        ]
    }

    withName: 'MULTIQC_.*' {
        ext.args   = { params.multiqc_title ? "--title \"${params.multiqc_title}\"" : '' }
    }

    withName: PICARD_COLLECTHSMETRICS {
        ext.args   = { "--TMP_DIR ." }
    }

    withName: PICARD_CREATESEQUENCEDICTIONARY {
        publishDir = [
            path: { "${params.outdir}/picard_createsequencedictionary" },
            mode: params.publish_dir_mode
        ]
    }

    withName: SAMTOOLS_INDEX {
        publishDir = [
            path: { "${params.outdir}/bwamem2_mem" },
            mode: params.publish_dir_mode
        ]
    }

    withName: SAMTOOLS_FAIDX {
        publishDir = [
            path: { "${params.outdir}/samtools_faidx" },
            mode: params.publish_dir_mode
        ]
    }

    withName: SEQFU_STATS {
        ext.args   = ''
        ext.prefix = 'seqfu'
    }

    withName: SEQTK_SAMPLE {
        ext.args = '-s100'
        publishDir = [
            path: { "${params.outdir}/seqtk" },
            mode: params.publish_dir_mode
        ]
    }

    withName: TOULLIGQC {
        ext.args = ''
        publishDir = [[
            path: { "${params.outdir}/toulligqc" },
            mode: params.publish_dir_mode,
            pattern: "*/images/*",
            saveAs: { filename -> "${meta.id}/images/${filename.tokenize('/')[-1]}" }
        ], [
            path: { "${params.outdir}/toulligqc" },
            mode: params.publish_dir_mode,
            pattern: "*/report.*",
            saveAs: { filename -> "${meta.id}/${filename.tokenize('/')[-1]}" }
        ]]
    }

    withName: UNTAR_KRAKEN2DB {
        publishDir = [
            path: { "${params.outdir}/kraken2_db" },
            mode: params.publish_dir_mode,
            enabled: params.kraken_save_uncompressed_db
        ]
    }
}
