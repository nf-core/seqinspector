def pipelines_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/'

nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"

    def test_scenario = [
        [
            name: "NovaSeq6000 data test - Fastp",
            params: [
                tools: 'fastp',
                tools_setup: null,
            ]
        ]
    ]

    def test_scenario = [
        [
            name: "NovaSeq6000 data test - Fastp and fastqc_trim",
            params: [
                tools: 'fastp,fastqc_trim',
                tools_setup: null,
            ]
        ]
    ]

    // Generate tests for each scenario
    test_scenario.each { scenario ->
        test(scenario.name, UTILS.getTest(scenario))
    }
}
