def pipelines_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/'

nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"

    def test_scenario = [
        [
            name: "PromethION data test",
            params: [
                genome : 'EB1',
                input: pipelines_testdata_base_path + 'seqinspector/samplesheet/1.0/promethion.csv',
                tools_bundle: 'ont',
            ],
        ],
    ]

    // Generate tests for each scenario
    test_scenario.each { scenario ->
        test(scenario.name, UTILS.getTest(scenario))
    }
}
