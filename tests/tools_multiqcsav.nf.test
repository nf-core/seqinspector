def pipelines_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/'

nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"

    def test_scenario = [
        [
            name: "NovaSeq6000 data test - multiqcsav",
            params: [
                tools: 'multiqcsav',
                tools_bundle: null,
            ],
            rundir_folder: pipelines_testdata_base_path + 'seqinspector/data/rundir/200624_A00834_0183_BHMTFYDRXX.tar.gz',
            rundir_samplesheet: pipelines_testdata_base_path + 'seqinspector/samplesheet/1.0/novaseq6000.csv',
        ],
        [
            name: "NovaSeq6000 data test - multiqcsav - stub",
            params: [
                tools: 'multiqcsav',
                tools_bundle: null,
            ],
            rundir_folder: pipelines_testdata_base_path + 'seqinspector/data/rundir/200624_A00834_0183_BHMTFYDRXX.tar.gz',
            rundir_samplesheet: pipelines_testdata_base_path + 'seqinspector/samplesheet/1.0/novaseq6000.csv',
            stub: true,
        ],
    ]

    // Generate tests for each scenario
    test_scenario.each { scenario ->
        test(scenario.name, UTILS.getTest(scenario))
    }
}
